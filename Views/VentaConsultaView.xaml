<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEstadios.Views.VentaConsultaView"
             BackgroundColor="{StaticResource Fondo}"
             Title="Ventas">

    <Grid RowDefinitions="Auto,*">

        <!-- 🔥 HEADER -->
        <VerticalStackLayout x:Name="HeaderSection" Padding="24,40,24,20" Spacing="16">

            <Label Text="Punto de Venta"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextoPrincipal}"/>

            <Border StrokeShape="RoundRectangle 18"
                    BackgroundColor="{StaticResource Card}"
                    Padding="14">
                <Picker x:Name="pickerEvento"
                        Title="Seleccionar evento"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextoPrincipal}"
                        BackgroundColor="Transparent"/>
            </Border>

            <!-- 📅 INFO -->
            <Label x:Name="lblFechaEvento"
                   Text="—"
                   FontSize="13"
                   TextColor="{StaticResource TextoSecundario}"
                   IsVisible="False"/>

        </VerticalStackLayout>

        <!-- 🔥 CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,40" Spacing="28">

                    <!-- 📊 DASHBOARD -->
                <Grid x:Name="DashboardSection" ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="16">


                    <Border BackgroundColor="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout>
                            <Label Text="Boletos"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label x:Name="lblTotalBoletos"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextoPrincipal}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1" BackgroundColor="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout>
                            <Label Text="Recaudado"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label x:Name="lblRecaudado"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Exito}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" BackgroundColor="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout>
                            <Label Text="Disponibles"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label x:Name="lblDisponibles"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BlancoPuro}"/>
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout>
                            <Label Text="Precio"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label x:Name="lblPrecioBoleto"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BlancoPuro}"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                    <!-- 📈 BARRA DE PROGRESO DE VENTAS -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2" BackgroundColor="{StaticResource Card}" Padding="18" StrokeShape="RoundRectangle 18">
                        <VerticalStackLayout Spacing="8">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Boletos vendidos"
                                       FontSize="11"
                                       TextColor="{StaticResource TextoSecundario}"
                                       VerticalOptions="Center"/>
                                <Label x:Name="lblPorcentajeVenta"
                                       Grid.Column="1"
                                       Text="0%"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource Exito}"
                                       VerticalOptions="Center"/>
                            </Grid>
                            <ProgressBar x:Name="progBoletos"
                                         Progress="0"
                                         ProgressColor="{StaticResource Exito}"
                                         BackgroundColor="{StaticResource Superficie}"
                                         HeightRequest="8"/>
                        </VerticalStackLayout>
                    </Border>


                <Label Text="Nueva Venta"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextoPrincipal}"/>

                <!-- ⚠️ BANNER DE ESTADO (se muestra cuando la venta está bloqueada) -->
                <Border x:Name="bannerEstado"
                        IsVisible="False"
                        BackgroundColor="#1A1A2E"
                        StrokeShape="RoundRectangle 14"
                        Padding="16,12">
                    <Label x:Name="lblEstadoVenta"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#F59E0B"
                           HorizontalTextAlignment="Center"/>
                </Border>

                <!-- 🧾 FORM -->
                <VerticalStackLayout x:Name="FormSection" Spacing="18">

                    <Entry x:Name="txtNombreCliente"
                           Placeholder="Nombre del cliente"
                           HeightRequest="55"
                           BackgroundColor="{StaticResource Card}"
                           TextColor="{StaticResource TextoPrincipal}"
                           PlaceholderColor="{StaticResource TextoTerciario}"
                           Margin="0,0,0,0"/>

                    <Entry x:Name="txtTelefono"
                           Placeholder="Teléfono (10 dígitos)"
                           Keyboard="Telephone"
                           MaxLength="10"
                           HeightRequest="55"
                           BackgroundColor="{StaticResource Card}"
                           TextColor="{StaticResource TextoPrincipal}"
                           PlaceholderColor="{StaticResource TextoTerciario}"
                           TextChanged="OnTelefonoTextChanged"/>

                    <!-- 📱 CONTADOR DÍGITOS TELÉFONO -->
                    <Label x:Name="lblContadorTelefono"
                           Text="0 / 10 dígitos"
                           FontSize="11"
                           TextColor="{StaticResource TextoTerciario}"
                           HorizontalOptions="End"
                           Margin="0,-12,4,0"/>


                    <Grid ColumnDefinitions="*,12,*">

                        <VerticalStackLayout Spacing="4">
                            <Entry x:Name="txtCantBoletos"
                                   Placeholder="Cantidad"
                                   Keyboard="Numeric"
                                   HeightRequest="55"
                                   BackgroundColor="{StaticResource Card}"
                                   TextColor="{StaticResource TextoPrincipal}"
                                   TextChanged="OnCantBoletosTextChanged"/>
                            <!-- 🎫 HINT BOLETOS DISPONIBLES -->
                            <Label x:Name="lblHintBoletos"
                                   Text=""
                                   FontSize="11"
                                   TextColor="{StaticResource TextoTerciario}"
                                   Margin="4,0,0,0"/>
                        </VerticalStackLayout>

                        <Border Grid.Column="2"
                                BackgroundColor="#052E16"
                                StrokeShape="RoundRectangle 14"
                                Padding="12"
                                VerticalOptions="Center">

                            <Label x:Name="lblTotalPagar"
                                   Text="$0.00"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Exito}"
                                   HorizontalOptions="Center"/>
                        </Border>

                    </Grid>

                </VerticalStackLayout>


                <!-- 🔥 BOTONES -->
                <Grid x:Name="BotonesSection" ColumnDefinitions="*,12,*">

                    <Button Text="Cancelar"
                            BackgroundColor="{StaticResource Superficie}"
                            TextColor="{StaticResource TextoPrincipal}"
                            CornerRadius="14"
                            HeightRequest="55"
                            Clicked="OnCancelarClicked"/>

                    <Button x:Name="btnConfirmar"
                            Grid.Column="2"
                            Text="Confirmar Venta"
                            BackgroundColor="{StaticResource BlancoPuro}"
                            TextColor="{StaticResource Black}"
                            CornerRadius="14"
                            HeightRequest="55"
                            FontAttributes="Bold"
                            Clicked="OnGuardarVentaClicked"/>

                </Grid>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
