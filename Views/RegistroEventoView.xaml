<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEstadios.Views.RegistroEventoView"
             BackgroundColor="{StaticResource Fondo}"
             Title="Nuevo Evento">

    <Grid RowDefinitions="Auto,*">

        <!-- 🔥 HEADER HERO -->
        <Grid x:Name="HeaderSection" HeightRequest="220" Padding="24,50,24,20">
            <Ellipse Fill="{StaticResource GradienteInicio}" Opacity="0.2"
                     WidthRequest="350" HeightRequest="350"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-120,-120,0"/>

            <VerticalStackLayout Spacing="6">
                <Label Text="CREAR EVENTO"
                       FontSize="12"
                       CharacterSpacing="2"
                       TextColor="{StaticResource TextoSecundario}"/>

                <Label Text="Nuevo Partido"
                       FontSize="34"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextoPrincipal}"/>

                <Label Text="Configura los detalles del encuentro"
                       FontSize="14"
                       TextColor="{StaticResource TextoTerciario}"/>
            </VerticalStackLayout>
        </Grid>

        <!-- 🔥 CONTENIDO -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,10,24,40" Spacing="28">

                <!-- 🏟️ MATCHUP (PROTAGONISTA) -->
                <Border x:Name="MatchupSection" StrokeShape="RoundRectangle 28"
                        BackgroundColor="{StaticResource Card}"
                        Padding="20">

                    <Grid ColumnDefinitions="*,Auto,*" VerticalOptions="Center">

                        <!-- LOCAL -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="LOCAL"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>

                            <Picker x:Name="pickerLocal"
                                    Title="Seleccionar"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextoPrincipal}"
                                    SelectedIndexChanged="OnEquipoLocalSeleccionado"/>
                        </VerticalStackLayout>

                        <!-- VS -->
                        <Label Grid.Column="1"
                               Text="VS"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextoSecundario}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

                        <!-- VISITANTE -->
                        <VerticalStackLayout Grid.Column="2" Spacing="6">
                            <Label Text="VISITANTE"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>

                            <Picker x:Name="pickerVisitante"
                                    Title="Primero elige local"
                                    IsEnabled="False"
                                    Opacity="0.45"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextoPrincipal}"/>
                        </VerticalStackLayout>

                    </Grid>
                </Border>

                <!-- 📍 INFO -->
                <VerticalStackLayout x:Name="DetallesSection" Spacing="16">

                    <Label Text="Detalles del Evento"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextoPrincipal}"/>

                    <!-- ESTADIO -->
                    <Border StrokeShape="RoundRectangle 18"
                            BackgroundColor="{StaticResource Card}"
                            Padding="14">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="ESTADIO"
                                   FontSize="11"
                                   TextColor="{StaticResource TextoSecundario}"/>

                            <Picker x:Name="pickerEstadio"
                                    Title="Seleccionar sede"
                                    SelectedIndexChanged="OnEstadioSeleccionado"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextoPrincipal}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- FECHA + HORA -->
                    <Grid ColumnDefinitions="*,12,*">

                        <Border StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource Card}"
                                Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="FECHA"
                                       FontSize="11"
                                       TextColor="{StaticResource TextoSecundario}"/>

                                <DatePicker x:Name="fechaEvento"
                                            MinimumDate="2026-01-01"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource TextoPrincipal}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource Card}"
                                Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="HORA"
                                       FontSize="11"
                                       TextColor="{StaticResource TextoSecundario}"/>

                                <TimePicker x:Name="horaEvento"
                                            BackgroundColor="Transparent"
                                            TextColor="{StaticResource TextoPrincipal}"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <!-- 🎟️ BOLETOS -->
                <VerticalStackLayout x:Name="BoletosSection" Spacing="16">

                    <Label Text="Boletos"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextoPrincipal}"/>

                    <Grid ColumnDefinitions="*,12,*">

                        <Border StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource Card}"
                                Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="AFORO"
                                       FontSize="11"
                                       TextColor="{StaticResource TextoSecundario}"/>

                                <Entry x:Name="txtTotalBoletos"
                                       Placeholder="Ej. 5000"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource TextoPrincipal}"/>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 18"
                                BackgroundColor="{StaticResource Card}"
                                Padding="14">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="PRECIO"
                                       FontSize="11"
                                       TextColor="{StaticResource TextoSecundario}"/>

                                <Entry x:Name="txtPrecio"
                                       Placeholder="Ej: 250.00"
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent"
                                       TextColor="{StaticResource TextoPrincipal}"/>
                            </VerticalStackLayout>
                        </Border>

                    </Grid>
                </VerticalStackLayout>

                <!-- 🔥 CTA -->
                <Button x:Name="btnGuardar"
                        Text="Publicar Evento"
                        HeightRequest="60"
                        CornerRadius="18"
                        FontAttributes="Bold"
                        BackgroundColor="{StaticResource BlancoPuro}"
                        TextColor="{StaticResource Black}"
                        Clicked="OnRegistrarPartidoClicked"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>