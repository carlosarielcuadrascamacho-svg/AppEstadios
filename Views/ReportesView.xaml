<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="AppEstadios.Views.ReportesView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Fondo}">

    <Grid>

        <maps:Map x:Name="mapaEventos"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill"
                  IsShowingUser="False"
                  MapClicked="OnMapClicked"/>

        <!-- 🔥 HEADER FLOTANTE -->
        <Border x:Name="headerOverlay"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="16,50,16,0"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="#CC121212"
                Padding="14,10"
                Stroke="#22FFFFFF">

            <Grid ColumnDefinitions="Auto,*,Auto" VerticalOptions="Center">

                <Label Text="location_on" FontFamily="MaterialSymbols" FontSize="18"
                       VerticalOptions="Center"/>

                <VerticalStackLayout Grid.Column="1" Spacing="0" Margin="8,0">
                    <Label Text="Eventos cercanos"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BlancoPuro}"/>
                    <Label x:Name="lblContadorPines"
                           Text="Cargando..."
                           FontSize="11"
                           TextColor="{StaticResource TextoTerciario}"/>
                </VerticalStackLayout>

                <!-- posible futuro botón -->
                <Label Grid.Column="2"
                       Text="⋯"
                       FontSize="20"
                       TextColor="{StaticResource TextoSecundario}"
                       VerticalOptions="Center"/>

            </Grid>
        </Border>

        <!-- 🔥 MODO RUTA TOOLBAR -->
        <Border x:Name="toolbarRuta"
                HorizontalOptions="Fill"
                VerticalOptions="Start"
                Margin="16,50,16,0"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="#1A237E"
                Padding="14,12"
                IsVisible="False"
                Stroke="#3F51B5">
            <Grid ColumnDefinitions="*, Auto, Auto" VerticalOptions="Center" ColumnSpacing="10">
                <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                    <Label Text="Modo Ruta activo"
                           FontSize="11"
                           TextColor="#90CAF9"
                           FontAttributes="Bold"/>
                    <Label Text="Toca el mapa para colocar tu origen"
                           FontSize="12"
                           TextColor="#FFFFFF"
                           VerticalOptions="Center"/>
                </VerticalStackLayout>
                <Button Grid.Column="1" Text="Cancelar"
                        BackgroundColor="#283593" TextColor="#90CAF9"
                        Padding="12,0" HeightRequest="36" CornerRadius="8"
                        FontSize="13" Clicked="OnCancelarRutaClicked" />
                <Button x:Name="btnConfirmarRuta" Grid.Column="2" Text="Confirmar"
                        BackgroundColor="#E3F2FD" TextColor="#1A237E"
                        FontAttributes="Bold" Padding="15,0" HeightRequest="36" CornerRadius="8"
                        FontSize="13" Clicked="OnConfirmarRutaClicked" IsEnabled="False" />
            </Grid>
        </Border>

        <!-- 🔥 LOADING OVERLAY (más ligero) -->
        <Grid x:Name="overlayLoading"
              BackgroundColor="#66000000"
              IsVisible="True">

            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="14">

                <ActivityIndicator IsRunning="True"
                                   WidthRequest="42"
                                   HeightRequest="42"
                                   Color="{StaticResource BlancoPuro}"/>

                <Label x:Name="lblLoadingTexto"
                       Text="Cargando eventos..."
                       FontSize="13"
                       TextColor="{StaticResource TextoPrincipal}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- 🔥 EMPTY STATE -->
        <Grid x:Name="overlayVacio"
              BackgroundColor="#AA000000"
              IsVisible="False">

            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Spacing="14"
                                 Padding="30">

                <Label Text="explore" FontFamily="MaterialSymbols"
                       FontSize="54"
                       HorizontalOptions="Center"
                       Opacity="0.85"/>

                <Label Text="Sin eventos"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextoPrincipal}"
                       HorizontalOptions="Center"/>

                <Label Text="Cuando crees eventos, aparecerán aquí en el mapa."
                       FontSize="13"
                       TextColor="{StaticResource TextoSecundario}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

            </VerticalStackLayout>
        </Grid>

        <!-- 🔥 FONDO INTERACTIVO -->
        <Grid x:Name="fondoOscuro"
              BackgroundColor="#99000000"
              IsVisible="False">

            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMapaTapped"/>
            </Grid.GestureRecognizers>
        </Grid>

        <!-- 🔥 BOTTOM SHEET MODERNO -->
        <Border x:Name="bottomSheet"
                VerticalOptions="End"
                Margin="16,0,16,24"
                StrokeShape="RoundRectangle 28"
                BackgroundColor="#E6121212"
                Stroke="#22FFFFFF"
                IsVisible="False">

            <Grid Padding="20,14,20,20"
                  RowDefinitions="Auto,Auto,Auto,Auto">

                <!-- handle -->
                <BoxView HeightRequest="5"
                         WidthRequest="50"
                         Color="#555"
                         CornerRadius="3"
                         HorizontalOptions="Center"
                         Margin="0,0,0,16"/>

                <!-- info principal -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14">

                    <Border WidthRequest="56"
                            HeightRequest="56"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="{StaticResource Superficie}">

                        <Label Text="stadium" FontFamily="MaterialSymbols"
                               FontSize="26"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="2"
                                         VerticalOptions="Center">

                        <Label x:Name="lblCardEstadio"
                               Text="—"
                               FontSize="17"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextoPrincipal}"/>

                        <Label x:Name="lblCardPartido"
                               Text="—"
                               FontSize="13"
                               TextColor="{StaticResource TextoSecundario}"/>
                    </VerticalStackLayout>

                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource BlancoPuro}"
                            Padding="8,4"
                            StrokeShape="RoundRectangle 10"
                            VerticalOptions="Start">

                        <Label Text="EN VIVO"
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Black}"/>
                    </Border>

                </Grid>

                <!-- detalles y estadísticas -->
                <Grid Grid.Row="2"
                      RowDefinitions="Auto, Auto"
                      ColumnDefinitions="*,*"
                      RowSpacing="15"
                      ColumnSpacing="10"
                      Margin="0,18,0,0">

                    <!-- Fecha -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Fecha" FontSize="10" TextColor="{StaticResource TextoTerciario}"/>
                        <Label x:Name="lblCardFecha" Text="—" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextoPrincipal}"/>
                    </VerticalStackLayout>

                    <!-- Hora -->
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Hora" FontSize="10" TextColor="{StaticResource TextoTerciario}"/>
                        <Label x:Name="lblCardHora" Text="—" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextoPrincipal}"/>
                    </VerticalStackLayout>

                    <!-- Boletos -->
                    <VerticalStackLayout Grid.Row="1" Spacing="4">
                        <Label Text="Boletos Vendidos" FontSize="10" TextColor="{StaticResource TextoTerciario}"/>
                        <Label x:Name="lblCardBoletos" Text="..." FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Primario}"/>
                    </VerticalStackLayout>

                    <!-- Recaudado -->
                    <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4">
                        <Label Text="Recaudado" FontSize="10" TextColor="{StaticResource TextoTerciario}"/>
                        <Label x:Name="lblCardRecaudado" Text="..." FontSize="14" FontAttributes="Bold" TextColor="#4CAF50"/>
                    </VerticalStackLayout>

                </Grid>

                <!-- botón cómo llegar -->
                <Button Grid.Row="3"
                        x:Name="btnComoLlegar"
                        Text="Cómo llegar"
                        ImageSource="{FontImage FontFamily=MaterialSymbols, Glyph=route, Size=20, Color=#000000}"
                        BackgroundColor="{StaticResource BlancoPuro}"
                        TextColor="{StaticResource Fondo}"
                        FontAttributes="Bold"
                        CornerRadius="14"
                        HeightRequest="48"
                        Margin="0,20,0,0"
                        Clicked="OnComoLlegarClicked" />

            </Grid>
        </Border>

    </Grid>
</ContentPage>