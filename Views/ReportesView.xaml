<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppEstadios.Views.ReportesView"
             BackgroundColor="{StaticResource Fondo}"
             Title="Reportes">

    <Grid RowDefinitions="Auto, *">

        <!-- ══════════ HEADER ══════════ -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="{StaticResource Secundario}"
                             Padding="20,16,20,20" Spacing="6">
            <BoxView Color="#1E3A5F" Opacity="0.7"
                     HorizontalOptions="Fill" HeightRequest="3" Margin="-20,-16,-20,10"/>

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Border BackgroundColor="#2D1B69" StrokeShape="RoundRectangle 12"
                        WidthRequest="42" HeightRequest="42"
                        Stroke="{StaticResource Acento}" StrokeThickness="1">
                    <Label Text="📊" FontSize="20"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                    <Label Text="REPORTE GLOBAL" FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource Acento}"/>
                    <Label Text="Estadísticas y próximos eventos"
                           FontSize="12" TextColor="{StaticResource TextoSecundario}"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- ══════════ CUERPO ══════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="18">

                <!-- ─── BANNER: MAPA / ZONA VISUAL ─── -->
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource GrisBorde}"
                        StrokeThickness="1"
                        BackgroundColor="{StaticResource Superficie}"
                        HeightRequest="200">
                    <Grid>
                        <!-- Fondo simulado del mapa -->
                        <BoxView Color="#0E1A2E" HorizontalOptions="Fill" VerticalOptions="Fill"/>

                        <!-- Patrón de cuadrícula simulado -->
                        <BoxView Color="#1C2C40" Opacity="0.6"
                                 HorizontalOptions="Fill" VerticalOptions="Fill"/>

                        <!-- Etiqueta de mapa -->
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                             Spacing="8">
                            <Label Text="🗺️" FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="Mapa de Eventos Futuros"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextoSecundario}"
                                   HorizontalOptions="Center"/>
                            <Border BackgroundColor="#1E3A5F" StrokeShape="RoundRectangle 20"
                                    Stroke="#3B82F6" StrokeThickness="1"
                                    Padding="14,6" HorizontalOptions="Center">
                                <Label Text="VER MAPA COMPLETO" FontSize="11" FontAttributes="Bold"
                                       TextColor="{StaticResource Primario}"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Pin de estadio activo -->
                        <Label Text="📍" FontSize="28"
                               HorizontalOptions="Start" VerticalOptions="Start"
                               Margin="50,30,0,0"/>
                        <Label Text="📍" FontSize="20" Opacity="0.5"
                               HorizontalOptions="End" VerticalOptions="End"
                               Margin="0,0,80,50"/>
                    </Grid>
                </Border>

                <!-- ─── TARJETA: ESTADIO SELECCIONADO ─── -->
                <Border StrokeShape="RoundRectangle 20"
                        Stroke="#3B82F6" StrokeThickness="1"
                        BackgroundColor="{StaticResource Card}"
                        Padding="18">
                    <HorizontalStackLayout Spacing="16">

                        <!-- Imagen/icono del estadio -->
                        <Border WidthRequest="70" HeightRequest="70"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="#1E3A5F"
                                Stroke="#3B82F6" StrokeThickness="1">
                            <Label Text="🏟️" FontSize="32"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>

                        <!-- Info del estadio -->
                        <VerticalStackLayout VerticalOptions="Center" Spacing="4" HorizontalOptions="FillAndExpand">
                            <Label x:Name="lblNombreEstadio"
                                   Text="Estadio Seleccionado"
                                   FontSize="17" FontAttributes="Bold"
                                   TextColor="{StaticResource TextoPrincipal}"/>
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="⚽" FontSize="13"/>
                                <Label x:Name="lblProximoEvento"
                                       Text="Local vs Visitante"
                                       FontSize="13"
                                       TextColor="{StaticResource TextoSecundario}"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="6">
                                <Border BackgroundColor="#1E3A5F" StrokeShape="RoundRectangle 8"
                                        Padding="8,3" Stroke="Transparent">
                                    <Label x:Name="lblFechaPin"
                                           Text="24 de Mayo, 20:00"
                                           FontSize="11" FontAttributes="Bold"
                                           TextColor="{StaticResource Primario}"/>
                                </Border>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </HorizontalStackLayout>
                </Border>

                <!-- ─── SECCIÓN: RESUMEN DEL EVENTO ─── -->
                <Label Text="RESUMEN FINANCIERO" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource TextoTerciario}"
                       Margin="4,0"/>

                <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">

                    <!-- Boletos vendidos -->
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource GrisBorde}" StrokeThickness="1"
                            BackgroundColor="{StaticResource Card}" Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🎫" FontSize="22"/>
                            <Label Text="Vendidos" FontSize="12"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label Text="—" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource TextoPrincipal}"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Total recaudado -->
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 16"
                            Stroke="#064E3B" StrokeThickness="1"
                            BackgroundColor="#0A1F1A" Padding="16,14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="💵" FontSize="22"/>
                            <Label Text="Recaudado" FontSize="12"
                                   TextColor="{StaticResource TextoSecundario}"/>
                            <Label Text="$0.00" FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource Exito}"/>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- ─── PRÓXIMOS EVENTOS (Placeholder list) ─── -->
                <Label Text="PRÓXIMOS EVENTOS" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource TextoTerciario}"
                       Margin="4,6,0,0"/>

                <!-- Item evento 1 -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource GrisBorde}" StrokeThickness="1"
                        BackgroundColor="{StaticResource Card}" Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <!-- Fecha -->
                        <Border Grid.Column="0" BackgroundColor="#1E3A5F"
                                StrokeShape="RoundRectangle 10" Padding="10,6"
                                WidthRequest="50" Stroke="Transparent">
                            <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                                <Label Text="24" FontSize="18" FontAttributes="Bold"
                                       TextColor="{StaticResource Primario}"
                                       HorizontalOptions="Center"/>
                                <Label Text="MAY" FontSize="9" FontAttributes="Bold"
                                       TextColor="{StaticResource TextoSecundario}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <!-- Info -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                            <Label Text="Local FC vs Visitante United" FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextoPrincipal}"/>
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🏟️ Estadio Principal" FontSize="12"
                                       TextColor="{StaticResource TextoSecundario}"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <!-- Hora -->
                        <Label Grid.Column="2" Text="20:00" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextoTerciario}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Espacio inferior -->
                <BoxView HeightRequest="20" Color="Transparent"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>