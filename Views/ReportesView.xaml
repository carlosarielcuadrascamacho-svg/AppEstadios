<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Syncfusion.Maui.Maps;assembly=Syncfusion.Maui.Maps"
             x:Class="AppEstadios.Views.ReportesView"
             Title="Mapa"
             Shell.NavBarIsVisible="False">

    <!--
        CAPAS (z-order de abajo hacia arriba):
          1. SfMaps de Syncfusion — full screen con OpenStreetMap
          2. Header flotante semitransparente (esquina superior)
          3. Overlay de carga
          4. Overlay de estado vacío
          5. Bottom Sheet (tarjeta inferior al tocar un pin)
    -->
    <Grid>

        <!-- ══════════════════════════════════════════════════
             CAPA 1 — MAPA FULL SCREEN (OpenStreetMap, sin API key)
        ══════════════════════════════════════════════════ -->
        <maps:SfMaps x:Name="mapaEventos"
                     HorizontalOptions="Fill"
                     VerticalOptions="Fill">
            <maps:SfMaps.Layer>
                <maps:MapTileLayer x:Name="capaMapa"
                                   UrlTemplate="https://tile.openstreetmap.org/{z}/{x}/{y}.png"
                                   ZoomLevel="5"
                                   MarkerSelected="OnMarkerClicked">

                    <!-- Comportamiento de zoom y paneo -->
                    <maps:MapTileLayer.ZoomPanBehavior>
                        <maps:MapZoomPanBehavior EnableZooming="True"
                                                 EnablePanning="True"
                                                 ZoomLevel="5"/>
                    </maps:MapTileLayer.ZoomPanBehavior>

                    <!-- Colección de marcadores (se llena desde el code-behind) -->
                    <maps:MapTileLayer.Markers>
                        <maps:MapMarkerCollection x:Name="coleccionMarcadores"/>
                    </maps:MapTileLayer.Markers>

                    <!-- Template visual del marcador: emoji de estadio + nombre -->
                    <maps:MapTileLayer.MarkerTemplate>
                        <DataTemplate>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 Spacing="0">
                                <!-- Pin emoji grande -->
                                <Label Text="🏟️" FontSize="28"
                                       HorizontalOptions="Center"
                                       Margin="0,0,0,-4"/>
                                <!-- Etiqueta con nombre del estadio -->
                                <Border BackgroundColor="#DD1E3A5F"
                                        StrokeShape="RoundRectangle 6"
                                        Stroke="#3B82F6" StrokeThickness="1"
                                        Padding="6,3"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding Label}"
                                           FontSize="9" FontAttributes="Bold"
                                           TextColor="White"
                                           HorizontalOptions="Center"
                                           MaxLines="1"
                                           LineBreakMode="TailTruncation"/>
                                </Border>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </maps:MapTileLayer.MarkerTemplate>

                </maps:MapTileLayer>
            </maps:SfMaps.Layer>
        </maps:SfMaps>

        <!-- ══════════════════════════════════════════════════
             CAPA 2 — HEADER FLOTANTE (esquina superior)
        ══════════════════════════════════════════════════ -->
        <Border HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,52,0,0"
                StrokeShape="RoundRectangle 20"
                Stroke="#1E3A5F" StrokeThickness="1"
                BackgroundColor="#CC0F172A"
                Padding="14,10">
            <HorizontalStackLayout Spacing="10">
                <Border BackgroundColor="#1E3A5F" StrokeShape="RoundRectangle 8"
                        WidthRequest="32" HeightRequest="32" Stroke="Transparent">
                    <Label Text="🗺️" FontSize="15"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout VerticalOptions="Center" Spacing="1">
                    <Label Text="EVENTOS PRÓXIMOS" FontSize="10" FontAttributes="Bold"
                           TextColor="#3B82F6"/>
                    <Label x:Name="lblContadorPines" Text="Cargando..."
                           FontSize="11" TextColor="#94A3B8"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>
        </Border>

        <!-- ══════════════════════════════════════════════════
             CAPA 3 — OVERLAY DE CARGA
        ══════════════════════════════════════════════════ -->
        <Grid x:Name="overlayLoading"
              HorizontalOptions="Center" VerticalOptions="Center"
              IsVisible="True">
            <Border StrokeShape="RoundRectangle 20"
                    Stroke="#1E3A5F" StrokeThickness="1"
                    BackgroundColor="#EE0F172A" Padding="28,20">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="#3B82F6"
                                       WidthRequest="40" HeightRequest="40"/>
                    <Label Text="Cargando eventos próximos..."
                           FontSize="13" FontAttributes="Bold"
                           TextColor="#94A3B8" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             CAPA 4 — ESTADO VACÍO
        ══════════════════════════════════════════════════ -->
        <Grid x:Name="overlayVacio"
              HorizontalOptions="Center" VerticalOptions="Center"
              IsVisible="False">
            <Border StrokeShape="RoundRectangle 24"
                    Stroke="#2D1B69" StrokeThickness="1"
                    BackgroundColor="#EE0F172A" Padding="32,24">
                <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Label Text="📭" FontSize="52" HorizontalOptions="Center"/>
                    <Label Text="Sin eventos próximos" FontSize="16" FontAttributes="Bold"
                           TextColor="#E2E8F0" HorizontalOptions="Center"/>
                    <Label Text="No hay partidos programados en el futuro.&#10;Crea uno desde la pestaña Registro."
                           FontSize="12" TextColor="#94A3B8"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════
             CAPA 5 — BOTTOM SHEET (al tocar un pin)
        ══════════════════════════════════════════════════ -->
        <Border x:Name="bottomSheet"
                VerticalOptions="End" HorizontalOptions="Fill"
                Margin="14,0,14,28"
                StrokeShape="RoundRectangle 28"
                Stroke="#1E3A5F" StrokeThickness="1.5"
                BackgroundColor="#F00F172A"
                IsVisible="False">

            <Grid RowDefinitions="Auto,Auto,Auto" Padding="20,18,20,20" RowSpacing="0">

                <!-- Handle visual -->
                <BoxView Grid.Row="0"
                         WidthRequest="40" HeightRequest="4"
                         Color="#334155" CornerRadius="2"
                         HorizontalOptions="Center" Margin="0,0,0,16"/>

                <!-- Ícono + Nombre estadio + Badge -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="14" Margin="0,0,0,14">
                    <Border Grid.Column="0"
                            WidthRequest="56" HeightRequest="56"
                            StrokeShape="RoundRectangle 16"
                            BackgroundColor="#1E3A5F"
                            Stroke="#3B82F6" StrokeThickness="1.5">
                        <Label Text="🏟️" FontSize="26"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                        <Label x:Name="lblCardEstadio" Text="—"
                               FontSize="16" FontAttributes="Bold" TextColor="#F1F5F9"
                               LineBreakMode="TailTruncation"/>
                        <Label x:Name="lblCardPartido" Text="—"
                               FontSize="13" TextColor="#94A3B8"
                               LineBreakMode="TailTruncation"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 10"
                            BackgroundColor="#1E3A5F" Stroke="#3B82F6" StrokeThickness="1"
                            Padding="8,4" VerticalOptions="Start">
                        <Label Text="PRÓXIMO" FontSize="9" FontAttributes="Bold"
                               TextColor="#3B82F6"/>
                    </Border>
                </Grid>

                <!-- Fecha + Hora -->
                <Grid Grid.Row="2" ColumnDefinitions="*,16,*" ColumnSpacing="0">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#1E293B" StrokeThickness="1"
                            BackgroundColor="#1E293B" Padding="12,10">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📅" FontSize="16" VerticalOptions="Center"/>
                            <Label x:Name="lblCardFecha" Text="—"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#CBD5E1" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 14"
                            Stroke="#1E3A5F" StrokeThickness="1"
                            BackgroundColor="#1E3A5F" Padding="12,10">
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="⏰" FontSize="16" VerticalOptions="Center"/>
                            <Label x:Name="lblCardHora" Text="—"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#3B82F6" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- Área transparente para cerrar la bottom sheet al tocar el mapa -->
        <Grid x:Name="tapCerrarSheet"
              HorizontalOptions="Fill" VerticalOptions="Fill"
              IsVisible="False" BackgroundColor="Transparent">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnMapaTapped"/>
            </Grid.GestureRecognizers>
        </Grid>

    </Grid>
</ContentPage>